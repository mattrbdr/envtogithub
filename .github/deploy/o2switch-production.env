# Non-sensitive production deployment settings.
# Replace the placeholders before enabling the production workflow.
# Secrets stay in GitHub Actions secrets.

ALLOWED_ACTOR="mattrbdr"
DEPLOY_BRANCH="main"
NODE_VERSION="22"

INSTALL_COMMAND="npm ci"
CHECK_COMMANDS="npm run check"
BUILD_COMMAND="npm run build"
BUILD_OUTPUT="apps/web/dist"

# Paths are relative to the cPanel home directory.
REMOTE_PATH="envtogit.mrbdrs.fr/"
BACKUP_PATH="backups/etg-site"
KEEP_BACKUPS="5"
